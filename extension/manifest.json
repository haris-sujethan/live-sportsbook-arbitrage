{
  "manifest_version": 3,
  "name": "Arb Scanner",
  "version": "1.2",
  "description": "Live arbitrage detection",

  "permissions": ["scripting", "tabs"],

  "host_permissions": [
    "https://*.betmgm.ca/*",
    "https://*.pinnacle.ca/*",
    "https://sportsbook.thescore.bet/*",
    "https://sportsbook.draftkings.com/*",
    "https://*.betway.ca/*",
    "https://*.fanduel.ca/*",
    "https://*.bet365.ca/*",
    "http://localhost:8765/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://*.betmgm.ca/*"],
      "js": ["betmgm.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.betmgm.ca/*"],
      "js": ["relay.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.pinnacle.ca/*"],
      "js": ["pinnacle.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.pinnacle.ca/*"],
      "js": ["pinnacle_relay.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://sportsbook.thescore.bet/*",
        "https://sportsbook.draftkings.com/*",
        "https://*.betway.ca/*",
        "https://*.fanduel.ca/*",
        "https://*.bet365.ca/*"
      ],
      "js": ["soft_relay.js"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "service_worker": "background.js"
  }
}
